---
scenes:
 - level1
apis:
 - scene
register:
 - on_enter
 - on_update
---
-- Scoped to "level1": this on_update registration coexists with menu.evt's
-- on_update (different scene) and showcase.evt's global on_update.
local frames = 0

function on_enter()
  print("level1: on_enter (active scene = " .. tostring(scene.current()) .. ")")
end

function on_update(dt)
  frames = frames + 1
  if frames == 1 then print("level1: first update tick") end
end
