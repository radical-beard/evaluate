---
config:
 - game.toml
apis:
 - input
 - save
register:
 - on_start
 - on_update
 - on_physics_update
---
-- game.evt is the conductor: it tells the engine *what* to do at each
-- lifecycle point, but never runs the game loop itself (the engine owns that).
-- The `register:` block hands on_start/on_update to the engine, which calls
-- them as needed.

-- another evt module, loaded (and sandboxed) through the custom require loader
local enemy_factory = require("enemy_factory.evt")

local player

-- the engine calls this once, after the world is created
function on_start()
  -- a real call into the Godot C# engine. `godot` is ambient (default), so no
  -- declaration is needed; the type is resolved & cached on first use.
  print("running on " .. godot.OS.GetName())

  -- SQLite persistence: a launch counter that survives across runs.
  local launches = save.get("launch_count", 0) + 1
  save.set("launch_count", launches)
  print(string.format("launch #%d (persisted to SQLite)", launches))

  -- TOML now supports strings, bools, and string arrays.
  print(string.format("title=%q debug=%s tags=%s,%s",
    config.game.title, tostring(config.game.debug), config.game.tags[1], config.game.tags[2]))

  -- instance + signal binding: create a real Godot Timer, set/read a property
  -- (routes through the engine), connect a Lua callback to a signal, and fire it.
  local timer = godot.Timer.new()
  timer.wait_time = 2.5                                   -- property set -> engine
  print(string.format("timer.wait_time = %.1f", timer.wait_time))   -- property get
  timer:connect("timeout", function() print("timer 'timeout' -> lua callback fired") end)
  timer:emit_signal("timeout")                            -- method call -> triggers callback
  timer:free()

  -- Vector3 marshalling: std.vec3 <-> Godot Vector3 across the binding boundary.
  local node = godot.Node3D.new()
  node.position = std.vec3(1, 2, 3)                       -- std.vec3 -> Godot Vector3
  local np = node.position                                -- Godot Vector3 -> std.vec3
  print(string.format("node3d.position = (%.0f, %.0f, %.0f)", np.x, np.y, np.z))
  node:free()

  -- enums: godot.<Enum>.<Member> resolves to its numeric value.
  print(string.format("Key.Space=%d  MouseButton.Left=%d", godot.Key.Space, godot.MouseButton.Left))
  -- nested enum on a type: godot.<Type>.<NestedEnum>.<Member>
  print(string.format("Timer.TimerProcessCallback.Idle=%d", godot.Timer.TimerProcessCallback.Idle))

  -- exhaustive struct marshalling: read a Transform3D (table), modify, write back.
  local n3 = godot.Node3D.new()
  n3.position = std.vec3(5, 6, 7)
  local tf = n3.transform                          -- Transform3D -> {basis=..., origin={x,y,z}}
  tf.origin.x = 99
  n3.transform = tf                                -- table -> Transform3D (target-aware write)
  n3.quaternion = { x = 0, y = 0, z = 0, w = 1 }   -- table -> Quaternion
  n3:set_meta("hp", 100); n3:set_meta("tag", "boss")
  local metas = n3:get_meta_list()                 -- PackedStringArray -> list table
  print(string.format("transform.origin.x after rmw=%.0f  quat.w=%.0f  meta_count=%d",
    n3.position.x, n3.quaternion.w, #metas))
  n3:free()

  -- static methods with struct / packed-array signatures (the last coverage gap):
  local c = godot.Color.FromHsv(0.5, 1.0, 1.0)       -- static -> Color struct
  local args = godot.OS.GetCmdlineArgs()              -- static -> PackedStringArray
  print(string.format("Color.FromHsv->(%.2f,%.2f,%.2f)  OS.GetCmdlineArgs count=%d",
    c.r, c.g, c.b, #args))

  -- Vector2 marshalling.
  local n2 = godot.Node2D.new()
  n2.position = std.vec2(7, 8)
  local p2 = n2.position
  print(string.format("node2d.position = (%.0f, %.0f)", p2.x, p2.y))
  n2:free()

  -- Color and Lua-table <-> Godot Array, round-tripped through node metadata.
  local probe = godot.Node.new()
  probe:set_meta("tint", std.color(1, 0.5, 0))      -- std.color -> Godot Color
  probe:set_meta("tags", {"hero", "spawn"})         -- Lua table -> Godot Array
  local tint = probe:get_meta("tint")
  local tags = probe:get_meta("tags")
  print(string.format("tint=(%.1f,%.1f,%.1f,%.1f)  tags=%s,%s",
    tint.r, tint.g, tint.b, tint.a, tags[1], tags[2]))
  probe:free()

  player = require("player.evt")          -- character built from config.player defaults
  player.set_position(std.vec3(config.game.spawn))   -- std.vec3 accepts a 3-element list
  local p = player.get_position()
  print(string.format("player spawned at (%.1f, %.1f, %.1f), weapon dmg %.0f",
    p.x, p.y, p.z, player.get_base_weapon_damage()))

  -- std.* data types are C#-backed (not Lua tables): collect enemy handles.
  local enemies = std.vector()
  for _ = 1, config.game.enemy_count do
    enemies:push_back(enemy_factory.spawn())
  end
  print(string.format("spawned %d enemies (std.vector size = %d)",
    config.game.enemy_count, enemies:size()))
end

-- the engine calls this on the fixed physics tick (separate from on_update)
local physics_ticked = false
function on_physics_update(dt)
  if not physics_ticked then
    physics_ticked = true
    print(string.format("on_physics_update fired (dt=%.4f)", dt))
  end
end

-- the engine calls this every tick; dt is seconds since the previous frame
function on_update(dt)
  if input.is_down("right") then
    -- get_position returns a vec3 copy; mutate it, then write it back.
    -- (your custom dialect allows `pos.x += ...`; the base Lua 5.2 VM here
    --  does not, so the POC spells it out.)
    local pos = player.get_position()
    pos.x = pos.x + config.game.move_speed * dt
    player.set_position(pos)
    local p = player.get_position()
    print(string.format("player moved to x=%.3f", p.x))
  end
end
