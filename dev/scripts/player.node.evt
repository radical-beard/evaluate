---
config:
 - player.toml
apis:
 - input
register:
 - on_ready
 - on_update
---
-- A NODE script: behavior for one node. `self` IS the Godot Node3D this script
-- is attached to (declared in global.scene), so there is no spawning here.
function on_ready()
  self.position = std.vec3(config.player.start_pos)
  self:set_meta("base_weapon_damage", config.player.base_weapon_damage)
  local p = self.position
  print(string.format("player ready at (%.1f, %.1f, %.1f), weapon dmg %.0f",
    p.x, p.y, p.z, self:get_meta("base_weapon_damage")))
end

-- Fires while the player's node is alive — which, being global, is always.
function on_update(dt)
  if input.is_down("right") then
    local p = self.position
    p.x = p.x + config.player.move_speed * dt
    self.position = p
    print(string.format("player moved to x=%.3f", self.position.x))
  end
end
